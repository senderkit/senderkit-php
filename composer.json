{
  "name": "senderkit/senderkit-php",
  "description": "Official SenderKit PHP SDK — email, SMS, push & web-push.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://senderkit.com",
  "require": {
    "php": ">=8.1",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^1.1 || ^2.0",
    "php-http/discovery": "^1.19"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "php-http/mock-client": "^1.6",
    "guzzlehttp/guzzle": "^7.8",
    "nyholm/psr7": "^1.8",
    "symfony/yaml": "^6.4 || ^7.0"
  },
  "suggest": {
    "guzzlehttp/guzzle": "A PSR-18 client with timeout support (used automatically if installed).",
    "symfony/http-client": "Alternative PSR-18 client."
  },
  "autoload": { "psr-4": { "SenderKit\\": "src/" } },
  "autoload-dev": { "psr-4": { "SenderKit\\Tests\\": "tests/" } },
  "config": { "allow-plugins": { "php-http/discovery": true } }
}
